### 2. Schema (schemas/lesson_schema.py)
```python
from pydantic import BaseModel, Field, UUID4
from datetime import datetime
from typing import Optional

class LessonCreate(BaseModel):
    """Schema for creating lesson"""
    title: str = Field(..., min_length=3, max_length=200)
    content: dict
    
    class Config:
        json_schema_extra = {
            "example": {
                "title": "Algebra Basics",
                "content": {"topic": "linear equations"}
            }
        }

class LessonUpdate(BaseModel):
    """Schema for updating lesson (all optional)"""
    title: Optional[str] = Field(None, min_length=3, max_length=200)
    content: Optional[dict] = None

class LessonResponse(BaseModel):
    """Schema for lesson response"""
    id: UUID4
    teacher_id: UUID4
    title: str
    content: dict
    created_at: datetime
    updated_at: Optional[datetime]
    
    class Config:
        from_attributes = True  # Enables SQLAlchemy → Pydantic
```

### 3. Service (services/lesson_service.py)
```python
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select
from typing import List, Optional
from uuid import UUID

from app.db.models.lesson_model import Lesson
from app.schemas.lesson_schema import LessonCreate, LessonUpdate
from app.api.errors import NotFoundError

class LessonService:
    """Business logic for lessons"""
    
    @staticmethod
    async def create(
        db: AsyncSession,
        data: LessonCreate,
        teacher_id: UUID
    ) -> Lesson:
        """
        Create new lesson
        
        Args:
            db: Database session
            data: Validated lesson data
            teacher_id: ID of teacher creating lesson
            
        Returns:
            Created Lesson object
        """
        lesson = Lesson(teacher_id=teacher_id, **data.model_dump())
        db.add(lesson)
        await db.flush()
        await db.refresh(lesson)
        return lesson
    
    @staticmethod
    async def get_by_id(
        db: AsyncSession,
        lesson_id: UUID,
        current_user: dict = None
    ) -> Lesson:
        """
        Get lesson by ID with ownership check
        
        Raises:
            NotFoundError: If lesson doesn't exist
            ForbiddenError: If user cannot access this lesson
        """
        result = await db.execute(
            select(Lesson).where(Lesson.id == lesson_id)
        )
        lesson = result.scalar_one_or_none()
        if not lesson:
            raise NotFoundError("Lesson", str(lesson_id))
        
        # RBAC: Check school isolation
        if current_user and lesson.school_id != current_user.get("school_id"):
            raise ForbiddenError("Cannot access lesson from different school")
        
        return lesson
    
    @staticmethod
    async def update(
        db: AsyncSession,
        lesson_id: UUID,
        data: LessonUpdate
    ) -> Lesson:
        """Update lesson"""
        lesson = await LessonService.get_by_id(db, lesson_id)
        for field, value in data.model_dump(exclude_unset=True).items():
            setattr(lesson, field, value)
        await db.flush()
        await db.refresh(lesson)
        return lesson
    
    @staticmethod
    async def delete(db: AsyncSession, lesson_id: UUID) -> None:
        """Delete lesson"""
        lesson = await LessonService.get_by_id(db, lesson_id)
        await db.delete(lesson)
        await db.flush()
```

### 4. Route (api/v1/routes/lesson_routes.py)
```python
from fastapi import APIRouter, Depends, status
from sqlalchemy.ext.asyncio import AsyncSession
from uuid import UUID

from app.db.middleware import get_db
from app.api.v1.dependencies.supabase_auth import get_current_user
from app.api.responses import success_response
from app.schemas.lesson_schema import LessonCreate, LessonUpdate, LessonResponse
from app.services.lesson_service import LessonService

router = APIRouter(prefix="/lessons", tags=["Lessons"])

@router.post("/", response_model=dict, status_code=status.HTTP_201_CREATED)
async def create_lesson(
    data: LessonCreate,
    db: AsyncSession = Depends(get_db),
    current_user: dict = Depends(get_current_user)
):
    """
    Create new lesson (teachers only)
    
    - **title**: Lesson title (3-200 chars)
    - **content**: Lesson content (JSON object)
    """
    lesson = await LessonService.create(
        db=db,
        data=data,
        teacher_id=current_user["user_id"]
    )
    return success_response(
        data=LessonResponse.from_orm(lesson),
        message="Lesson created successfully"
    )

@router.get("/{lesson_id}", response_model=dict)
async def get_lesson(
    lesson_id: UUID,
    db: AsyncSession = Depends(get_db)
):
    """Get lesson by ID"""
    lesson = await LessonService.get_by_id(db, lesson_id)
    return success_response(data=LessonResponse.from_orm(lesson))

@router.put("/{lesson_id}", response_model=dict)
async def update_lesson(
    lesson_id: UUID,
    data: LessonUpdate,
    db: AsyncSession = Depends(get_db),
    current_user: dict = Depends(get_current_user)
):
    """Update lesson"""
    lesson = await LessonService.update(db, lesson_id, data)
    return success_response(
        data=LessonResponse.from_orm(lesson),
        message="Lesson updated successfully"
    )

@router.delete("/{lesson_id}", status_code=status.HTTP_204_NO_CONTENT)
async def delete_lesson(
    lesson_id: UUID,
    db: AsyncSession = Depends(get_db),
    current_user: dict = Depends(get_current_user)
):
    """Delete lesson"""
    await LessonService.delete(db, lesson_id)
    return None
```

