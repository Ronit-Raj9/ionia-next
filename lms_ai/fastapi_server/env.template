# LLM Provider Configuration
LLM_PROVIDER=groq
# Options: groq, openai, gemini

# API Keys (AT LEAST ONE IS REQUIRED)
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Model Selection
GRADING_MODEL=llama-3.1-70b-versatile
PERSONALIZATION_MODEL=llama-3.1-70b-versatile
LESSON_PLANNING_MODEL=llama-3.1-70b-versatile

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=true

# MongoDB (for student memory/context)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=ionia_lms

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Logging
LOG_LEVEL=INFO

